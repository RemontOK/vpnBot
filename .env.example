# --- App ---
APP_ENV=prod
API_HOST=0.0.0.0
API_PORT=8080
API_BASE_URL=http://127.0.0.1:8080
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN

# --- PostgreSQL ---
POSTGRES_DB=vpn_bot
POSTGRES_USER=vpn
POSTGRES_PASSWORD=vpnpass
POSTGRES_PORT=5432
POSTGRES_HOST=127.0.0.1

# --- YooKassa ---
YOOKASSA_SHOP_ID=PUT_SHOP_ID
YOOKASSA_SECRET_KEY=PUT_SECRET_KEY
YOOKASSA_RETURN_URL=https://t.me/your_bot

# --- Marzban ---
MARZBAN_BASE_URL=http://127.0.0.1:8000
MARZBAN_PUBLIC_BASE_URL=http://94.159.99.100:8000
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=admin
MARZBAN_USE_MOCK=true
MARZBAN_DEFAULT_PROTOCOL=vless
MARZBAN_DEFAULT_INBOUND_TAG=VLESS TCP
MARZBAN_VLESS_PROTOCOL=vless
MARZBAN_VLESS_INBOUND_TAG=VLESS TCP
MARZBAN_HYSTERIA_PROTOCOL=hysteria2
MARZBAN_HYSTERIA_INBOUND_TAG=HYSTERIA 2
MARZBAN_SUB_FALLBACK=
LEGACY_VPN_ISSUER_URL=
LEGACY_VPN_ISSUER_TOKEN=
VLESS_COMPAT_DOMAIN=
VLESS_COMPAT_PORT=443
VLESS_COMPAT_PATH=/ws{hash}
VLESS_COMPAT_SUB_PATH=/pac{hash}/sub
VLESS_COMPAT_SNI=
VLESS_COMPAT_SECURITY=tls
VLESS_COMPAT_FP=chrome
VLESS_COMPAT_TYPE=ws

# --- Plans ---
PLAN_STARTER_PRICE=100
PLAN_STARTER_DAYS=30
PLAN_STARTER_GB=100
PLAN_PRO_PRICE=250
PLAN_PRO_DAYS=30
PLAN_PRO_GB=300
PLAN_ULTRA_PRICE=600
PLAN_ULTRA_DAYS=90
PLAN_ULTRA_GB=1000
