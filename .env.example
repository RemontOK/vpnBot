# --- App ---
APP_ENV=prod
API_HOST=0.0.0.0
API_PORT=8080
API_BASE_URL=http://api:8080
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN

# --- PostgreSQL ---
POSTGRES_DB=vpn_bot
POSTGRES_USER=vpn
POSTGRES_PASSWORD=vpnpass
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# --- YooKassa ---
YOOKASSA_SHOP_ID=PUT_SHOP_ID
YOOKASSA_SECRET_KEY=PUT_SECRET_KEY
YOOKASSA_RETURN_URL=https://t.me/your_bot

# --- Marzban ---
MARZBAN_BASE_URL=http://host.docker.internal:8000
MARZBAN_PUBLIC_BASE_URL=http://your-server.example.com:8000
MARZBAN_USERNAME=PUT_MARZBAN_USERNAME
MARZBAN_PASSWORD=PUT_MARZBAN_PASSWORD
MARZBAN_USE_MOCK=true
MARZBAN_DEFAULT_PROTOCOL=vless
MARZBAN_DEFAULT_INBOUND_TAG=VLESS REALITY
MARZBAN_VLESS_PROTOCOL=vless
MARZBAN_VLESS_INBOUND_TAG=VLESS REALITY
MARZBAN_HYSTERIA_PROTOCOL=
MARZBAN_HYSTERIA_INBOUND_TAG=
MARZBAN_SUB_FALLBACK=

# --- Plans ---
PLAN_STARTER_PRICE=100
PLAN_STARTER_DAYS=30
PLAN_STARTER_GB=100
PLAN_PRO_PRICE=250
PLAN_PRO_DAYS=30
PLAN_PRO_GB=300
PLAN_ULTRA_PRICE=600
PLAN_ULTRA_DAYS=90
PLAN_ULTRA_GB=1000
